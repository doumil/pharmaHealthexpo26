# إعدادات جلب مسار Flutter ديناميكياً من الملفات التي يولدها التطبيق
# (هذا هو الأسلوب الرسمي لـ Flutter لمنع مشاكل الـ CI/CD)
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "Generated.xcconfig not found. Please run `flutter pub get` or build the project first."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in Generated.xcconfig."
end

# تحميل الـ podhelper.rb باستعمال المسار الديناميكي الحقيقي
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)

# تحديد إصدار نظام iOS الأدنى المتوافق مع خرائط جوجل
platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # تثبيت كافة الـ Plugins الخاصة بـ Flutter
  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # إجبار جميع الـ Pods والـ Plugins المستدعاة على استهداف iOS 14.0 لتفادي أي نزاع في الإصدارات
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end